# ══════════════════════════════════════════════════════════════════
#
# วิธีใช้:
#   1. Copy ไฟล์นี้เป็น .streamlit/secrets.toml
#   2. แทนที่ค่าต่างๆ ด้วยข้อมูลจริงของคุณ
#   3. ห้าม commit secrets.toml ขึ้น GitHub!
#      (เพิ่ม .streamlit/secrets.toml ใน .gitignore)
#
# ══════════════════════════════════════════════════════════════════

# ── Google Sheet ID หรือ URL (เลือกใส่อย่างใดอย่างหนึ่ง) ──────────

# แบบที่ 1: ใส่เฉพาะ Sheet ID (แนะนำ)
gsheet_id = "1iA81FWeNS1yLpwPtUBPs4-ufzUt5ZN9bVAMwBjTBU"

# แบบที่ 2: ใส่ URL เต็ม (ระบบจะดึง ID ให้อัตโนมัติ)
# gsheet_url = "https://docs.google.com/spreadsheets/d/1iA81FWeNS1yLpwPtUBPs4-ufzUt5ZN9bVAMwBjTBU/edit"

# ══════════════════════════════════════════════════════════════════
# Google Service Account Credentials
# ══════════════════════════════════════════════════════════════════
#
# วิธีได้ค่าเหล่านี้:
#   1. ไปที่ https://console.cloud.google.com
#   2. สร้าง Project → เปิด Google Sheets API + Google Drive API
#   3. IAM & Admin → Service Accounts → Create Service Account
#   4. Keys → Add Key → JSON → Download
#   5. เปิดไฟล์ JSON แล้ว copy ค่าต่างๆ มาใส่ด้านล่าง
#
# สำคัญ: Share Google Sheet ให้กับ client_email ด้านล่าง
#         โดยให้สิทธิ์ "Editor"
#
